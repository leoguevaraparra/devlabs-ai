# ============================================================
# DevLab Pro — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── Gemini AI API ──
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── Backend API URL ──
VITE_API_URL=https://devlabs-ai-server-production.up.railway.app

# ── Port Mapping ──
APP_PORT=80
DEV_PORT=5173
REDIS_PORT=6379

# ── Environment ──
NODE_ENV=production
