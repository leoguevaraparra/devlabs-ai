# ============================================================
# .dockerignore — Keep Docker build context clean and fast
# ============================================================

# ── Dependencies (installed inside container) ──
node_modules
.pnp
.pnp.js

# ── Build artifacts ──
dist
dist-ssr
build
*.tsbuildinfo

# ── Environment & secrets ──
.env
.env.*
env.local
*.local

# ── Version control ──
.git
.gitignore
.gitattributes

# ── IDE & editor configs ──
.idea
.vscode
*.code-workspace
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store

# ── Logs ──
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Testing ──
coverage
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx

# ── Documentation ──
README.md
DOCUMENTATION.md
LICENSE
CHANGELOG.md
*.md.resolved

# ── Docker (avoid recursive context) ──
Dockerfile
docker-compose*.yml
.dockerignore

# ── CI/CD ──
.github
.gitlab-ci.yml
.circleci
.travis.yml

# ── Misc ──
.eslintrc*
.prettierrc
metadata.json
*.tgz
